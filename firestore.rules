rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return signedIn() && request.auth.token.email == "acshrisundaram@gmail.com";
    }

    function currentClaimRole() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : "user";
    }

    function validRole(role) {
      return role in ["user", "volunteer", "government", "coordinator", "admin"];
    }

    function isAdmin() {
      return isAdminEmail() || currentClaimRole() == "admin";
    }

    function canManageWorkspace() {
      return signedIn() && (
        isAdminEmail()
        || currentClaimRole() in ["admin", "coordinator", "government"]
      );
    }

    function authEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function validVolunteerProfile() {
      return request.resource.data.keys().hasOnly([
          "id",
          "ownerUid",
          "fullName",
          "ngoGroup",
          "skills",
          "phone",
          "email",
          "availability",
          "location",
          "activityStatus",
          "verified",
          "visible",
          "createdAt",
          "updatedAt",
          "updatedBy"
        ])
        && request.resource.data.id is string
        && request.resource.data.ownerUid is string
        && request.resource.data.fullName is string
        && request.resource.data.ngoGroup is string
        && request.resource.data.skills is list
        && request.resource.data.phone is string
        && request.resource.data.email is string
        && request.resource.data.availability is string
        && request.resource.data.location is string
        && request.resource.data.activityStatus is string
        && request.resource.data.verified is bool
        && request.resource.data.visible is bool
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedBy is string
        && request.resource.data.activityStatus in ["available", "on call", "active", "inactive"];
    }

    function validDonationRecord() {
      return request.resource.data.keys().hasOnly([
          "ownerUid",
          "ownerEmail",
          "donorName",
          "kind",
          "amount",
          "paymentMethod",
          "message",
          "itemType",
          "quantity",
          "description",
          "contactDetails",
          "linkedRequestId",
          "linkedRequestTitle",
          "deliveryProof",
          "status",
          "verified",
          "archived",
          "flagged",
          "flagReason",
          "createdAt",
          "updatedAt",
          "updatedBy"
        ])
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerEmail is string
        && request.resource.data.donorName is string
        && request.resource.data.kind is string
        && request.resource.data.amount is int
        && request.resource.data.paymentMethod is string
        && request.resource.data.message is string
        && request.resource.data.itemType is string
        && request.resource.data.quantity is int
        && request.resource.data.description is string
        && request.resource.data.contactDetails is string
        && request.resource.data.linkedRequestId is string
        && request.resource.data.linkedRequestTitle is string
        && request.resource.data.deliveryProof is string
        && request.resource.data.status is string
        && request.resource.data.verified is bool
        && request.resource.data.archived is bool
        && request.resource.data.flagged is bool
        && request.resource.data.flagReason is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedBy is string
        && request.resource.data.kind in ["money", "item"]
        && request.resource.data.status in ["submitted", "verified", "packed", "dispatched", "delivered"];
    }

    function validWorkspacePayload() {
      return request.resource.data.keys().hasOnly(["state", "updatedAt"])
        && request.resource.data.state is map
        && request.resource.data.state.keys().hasOnly([
          "requests",
          "volunteers",
          "assignments",
          "artifacts",
          "activityLog",
          "history",
          "meta",
          "lastUpdated"
        ])
        && request.resource.data.state.requests is list
        && request.resource.data.state.volunteers is list
        && request.resource.data.state.assignments is list
        && request.resource.data.state.artifacts is list
        && request.resource.data.state.activityLog is list
        && request.resource.data.state.history is list
        && request.resource.data.state.meta is map
        && request.resource.data.state.meta.keys().hasOnly(["revision", "updatedBy", "updatedAt"])
        && request.resource.data.state.meta.revision is int
        && request.resource.data.state.meta.updatedBy is string
        && request.resource.data.state.meta.updatedAt is string
        && request.resource.data.state.lastUpdated is string
        && request.resource.data.updatedAt is string;
    }

    function validProfileShape(userId) {
      return request.resource.data.keys().hasOnly([
        "uid",
        "email",
        "displayName",
        "photoURL",
        "location",
        "role",
        "requestedRole",
        "updatedAt",
        "updatedBy"
      ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.location is string
        && request.resource.data.role is string
        && request.resource.data.requestedRole is string
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedBy is string
        && validRole(request.resource.data.role)
        && validRole(request.resource.data.requestedRole);
    }

    function ownProfileCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && validProfileShape(userId)
        && request.resource.data.role == "user"
        && request.resource.data.email == authEmail();
    }

    function protectedProfileFieldsLocked(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role;
    }

    function ownProfileUpdate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && validProfileShape(userId)
        && protectedProfileFieldsLocked(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["displayName", "photoURL", "location", "requestedRole", "updatedAt", "updatedBy"]);
    }

    function ownVolunteerCreate(volunteerId) {
      return signedIn()
        && request.auth.uid == volunteerId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id == volunteerId
        && request.resource.data.verified == false
        && validVolunteerProfile();
    }

    function ownVolunteerUpdate(volunteerId) {
      return signedIn()
        && request.auth.uid == volunteerId
        && validVolunteerProfile()
        && request.resource.data.id == resource.data.id
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.verified == resource.data.verified
        && request.resource.data.visible == resource.data.visible;
    }

    function managerVolunteerUpdate() {
      return canManageWorkspace()
        && validVolunteerProfile()
        && request.resource.data.id == resource.data.id
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function ownDonationCreate() {
      return signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == authEmail()
        && request.resource.data.status == "submitted"
        && request.resource.data.verified == false
        && request.resource.data.archived == false
        && request.resource.data.flagged == false
        && request.resource.data.flagReason == ""
        && validDonationRecord();
    }

    function managerDonationUpdate() {
      return canManageWorkspace()
        && validDonationRecord()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.ownerEmail == resource.data.ownerEmail
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /resourceflow/{workspaceId} {
      allow read: if signedIn();
      allow create, update: if canManageWorkspace() && validWorkspacePayload();
      allow delete: if canManageWorkspace();
    }

    match /resourceflowUsers/{userId} {
      allow read: if signedIn();
      allow create: if ownProfileCreate(userId);
      allow update: if ownProfileUpdate(userId);
      allow delete: if isAdmin();
    }

    match /resourceflowVolunteerProfiles/{volunteerId} {
      allow read: if signedIn();
      allow create: if ownVolunteerCreate(volunteerId);
      allow update: if ownVolunteerUpdate(volunteerId) || managerVolunteerUpdate();
      allow delete: if canManageWorkspace();
    }

    match /resourceflowDonations/{donationId} {
      allow create: if ownDonationCreate();
      allow read: if signedIn()
        && (
          request.auth.uid == resource.data.ownerUid
          || canManageWorkspace()
        );
      allow update: if managerDonationUpdate();
      allow delete: if canManageWorkspace();
    }

    match /resourceflowNotifications/{notificationId} {
      allow read, write: if false;
    }

    match /resourceflowErrorLogs/{errorId} {
      allow read, write: if false;
    }

    match /resourceflowAudit/{auditId} {
      allow read, write: if false;
    }
  }
}
