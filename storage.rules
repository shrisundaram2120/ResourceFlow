rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return signedIn() && request.auth.token.email == "acshrisundaram@gmail.com";
    }

    function currentClaimRole() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : "user";
    }

    function canManageWorkspace() {
      return signedIn() && (
        isAdminEmail()
        || currentClaimRole() in ["admin", "coordinator", "government"]
      );
    }

    function allowedArtifactType() {
      return request.resource.contentType is string
        && (
          request.resource.contentType.matches("image/.*")
          || request.resource.contentType == "application/pdf"
          || request.resource.contentType == "text/plain"
        );
    }

    function validArtifactFileName(fileName) {
      return fileName.matches("^[A-Za-z0-9._-]+$");
    }

    function validArtifactUpload(fileName) {
      return request.resource != null
        && validArtifactFileName(fileName)
        && request.resource.size > 0
        && request.resource.size < 10 * 1024 * 1024
        && allowedArtifactType();
    }

    match /resourceflow/{workspaceId}/artifacts/{fileName} {
      allow read: if signedIn();
      allow create: if canManageWorkspace() && validArtifactUpload(fileName);
      allow update: if false;
      allow delete: if canManageWorkspace();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
